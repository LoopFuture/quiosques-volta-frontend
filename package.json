{
  "name": "volta-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "pnpm build:ios && pnpm build:android",
    "build:local:ios": "mkdir -p dist/ios/builds && pnpm exec eas build --platform ios --profile development-simulator --local --output ./dist/ios/builds/volta-frontend-development-simulator.tar.gz --non-interactive",
    "build:local:android": "mkdir -p dist/android/builds && pnpm exec eas build --platform android --profile development --local --output ./dist/android/builds/volta-frontend-development.apk --non-interactive",
    "build:local": "pnpm build:local:ios && pnpm build:local:android",
    "build:ios": "tamagui build --target native ./src -- expo export --platform ios --output-dir dist/ios",
    "build:android": "tamagui build --target native ./src -- expo export --platform android --output-dir dist/android",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:coverage": "jest --coverage --runInBand --watch=false",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --watch=false",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/native": "^7.0.14",
    "@tamagui/colors": "2.0.0-rc.22",
    "@tamagui/config": "^2.0.0-rc.22",
    "@tamagui/core": "2.0.0-rc.22",
    "@tamagui/font-inter": "2.0.0-rc.22",
    "@tamagui/lucide-icons": "^2.0.0-rc.22",
    "@tamagui/themes": "2.0.0-rc.22",
    "@tamagui/toast": "^2.0.0-rc.22",
    "@tanstack/react-query": "^5.90.21",
    "babel-preset-expo": "~55.0.10",
    "expo": "^55.0.5",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.13",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "tamagui": "^2.0.0-rc.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/metro-runtime": "~55.0.6",
    "@tamagui/babel-plugin": "^2.0.0-rc.22",
    "@tamagui/cli": "2.0.0-rc.22",
    "@tamagui/metro-plugin": "2.0.0-rc.22",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^24.3.0",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.8.1",
    "react-dom": "19.2.0",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "react-test-renderer": "19.2.0"
    },
    "allowedDeprecatedVersions": {
      "abab": "2.0.6",
      "domexception": "4.0.0",
      "glob": "7.2.3 || 9.3.5",
      "inflight": "1.0.6",
      "rimraf": "3.0.2",
      "whatwg-encoding": "2.0.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "marked-terminal@5.2.0>marked": "14"
      }
    }
  }
}
