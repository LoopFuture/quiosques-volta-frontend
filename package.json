{
  "name": "volta-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "pnpm build:ios && pnpm build:android",
    "build:local:ios": "mkdir -p dist/ios/builds && pnpm exec eas build --platform ios --profile development --local --output ./dist/ios/builds/volta-frontend-development.tar.gz --non-interactive",
    "build:local:android": "mkdir -p dist/android/builds && pnpm exec eas build --platform android --profile development --local --output ./dist/android/builds/volta-frontend-development.apk --non-interactive",
    "build:local": "pnpm build:local:ios && pnpm build:local:android",
    "build:ios": "tamagui build --target native ./src -- expo export --platform ios --output-dir dist/ios --source-maps && pnpm upload:sourcemaps -- dist/ios",
    "build:android": "tamagui build --target native ./src -- expo export --platform android --output-dir dist/android --source-maps && pnpm upload:sourcemaps -- dist/android",
    "lint": "eslint .",
    "lint:file": "eslint --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:file": "jest --runInBand --watch=false",
    "test:coverage": "jest --coverage --runInBand --watch=false",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --runInBand --watch=false",
    "typecheck": "tsc --noEmit",
    "upload:sourcemaps": "node ./scripts/upload-sentry-sourcemaps.mjs",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:ci",
    "validate:full": "pnpm validate && pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-menu/menu": "^2.0.0",
    "@react-navigation/native": "^7.1.33",
    "@sentry/cli": "2.58.4",
    "@sentry/react-native": "^7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tamagui/colors": "2.0.0-rc.22",
    "@tamagui/config": "2.0.0-rc.22",
    "@tamagui/core": "2.0.0-rc.22",
    "@tamagui/font-inter": "2.0.0-rc.22",
    "@tamagui/lucide-icons": "2.0.0-rc.22",
    "@tamagui/native": "2.0.0-rc.22",
    "@tamagui/themes": "2.0.0-rc.22",
    "@tamagui/toast": "2.0.0-rc.22",
    "@tanstack/react-query": "^5.90.21",
    "babel-preset-expo": "~55.0.10",
    "expo": "~55.0.5",
    "expo-auth-session": "~55.0.9",
    "expo-brightness": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-insights": "~55.0.11",
    "expo-linking": "~55.0.8",
    "expo-local-authentication": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-network": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.15",
    "i18next": "^25.8.17",
    "react": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "react-native": "0.83.2",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "sf-symbols-typescript": "^2.2.0",
    "tamagui": "2.0.0-rc.22",
    "zeego": "^3.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/metro-runtime": "~55.0.6",
    "@tamagui/babel-plugin": "2.0.0-rc.22",
    "@tamagui/cli": "2.0.0-rc.22",
    "@tamagui/metro-plugin": "2.0.0-rc.22",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^24.3.0",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.11",
    "prettier": "^3.8.1",
    "react-dom": "19.2.0",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "react-test-renderer": "19.2.0"
    },
    "allowedDeprecatedVersions": {
      "abab": "2.0.6",
      "domexception": "4.0.0",
      "glob": "7.2.3 || 9.3.5",
      "inflight": "1.0.6",
      "rimraf": "3.0.2",
      "text-encoding": "0.7.0",
      "whatwg-encoding": "2.0.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "marked-terminal@5.2.0>marked": "14"
      }
    }
  }
}
