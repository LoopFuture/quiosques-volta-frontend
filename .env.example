# Required auth runtime
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/volta
KEYCLOAK_CLIENT_ID=volta-mobile
KEYCLOAK_SCOPES=openid profile email

# Optional app API runtime
# Leave API_BASE_URL empty when using the in-app MSW mock API.
# API_MOCKING_ENABLED defaults to true in development/Jest and false in production.
API_BASE_URL=
API_MOCKING_ENABLED=true

# Optional Android push setup
# Set this to your local google-services.json path before building an Android app
# that should register for push notifications.
ANDROID_GOOGLE_SERVICES_FILE=

# Optional Sentry diagnostics
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Defaults to 1.0 in development and 0.0 in other environments.
SENTRY_TRACES_SAMPLE_RATE=

# Optional Sentry build-time upload config
# Used when uploading Expo export sourcemaps or native build artifacts during builds.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=
# Set to true for local/dev-client builds that should skip native Sentry uploads.
SENTRY_DISABLE_AUTO_UPLOAD=
# Use only as a fallback when you do not want upload failures to block a build.
SENTRY_ALLOW_FAILURE=
